    REDDIT["GET /api/reddit-search"]
  end

  subgraph external [External]
    LM[LM Studio or OpenAI-compatible API]
    BING[Bing News]
  end

  AS -->|"restSameOrigin"| PROXY
  AS --> MODELS
  AS --> SEARCH
  AS --> CHECK
  AS --> REDDIT
  PROXY --> LM
  SEARCH --> BING
  ST -->|"summary cache TTL"| AS

  subgraph extras [Related features]
    YT[YouTube suggestions KI JSON]
  end
  UI --> YT
